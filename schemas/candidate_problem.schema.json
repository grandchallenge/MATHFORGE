{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MATHFORGE Candidate Problem Card",
  "type": "object",
  "required": [
    "problem_id",
    "title",
    "domain_id",
    "status_signal",
    "grand_challenge_fit",
    "recommended_wp01",
    "foundational_profile",
    "knowledge_graph_refs",
    "classification_mapping_refs",
    "discovery_provenance"
  ],
  "properties": {
    "problem_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "status_signal": {
      "type": "string"
    },
    "source_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forge_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "grand_challenge_fit": {
      "type": "string"
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_wp01": {
      "type": "string"
    },
    "recommended_certification_route": {
      "type": "string"
    },
    "foundational_profile": {
      "type": "object"
    },
    "knowledge_graph_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "classification_mapping_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "discovery_provenance": {
      "type": "object",
      "required": [
        "source_ids",
        "reviewed_at",
        "reviewed_by"
      ],
      "properties": {
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewed_at": {
          "type": "string",
          "format": "date"
        },
        "reviewed_by": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
